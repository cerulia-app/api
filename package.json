{
  "name": "@cerulia/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/entrypoints/bun.ts",
    "dev:worker": "bun x wrangler dev",
    "build": "tsc --noEmit",
    "migrate": "bun run scripts/migrate-sqlite.mjs",
    "migrate:d1:local": "bun run scripts/migrate-d1.mjs --local",
    "migrate:d1:remote": "bun run scripts/migrate-d1.mjs --remote",
    "test": "bun test",
    "check": "tsc --noEmit && bun test"
  },
  "dependencies": {
    "@cerulia/protocol": "git+https://github.com/cerulia-app/protocol.git",
    "hono": "^4.10.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.3",
    "wrangler": "^4.41.0"
  }
}